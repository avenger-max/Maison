# ── Server ──────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ecommerce_db

# ── JWT ──────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

# ── CORS (your frontend URL) ─────────────
CLIENT_URL=http://127.0.0.1:5500
